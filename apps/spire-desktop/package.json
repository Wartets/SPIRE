{
  "name": "spire-desktop",
  "version": "0.1.0",
  "type": "module",
  "scripts": {
    "tauri": "tauri",
    "dev": "tauri dev",
    "dev:web": "svelte-kit sync && vite dev",
    "build": "tauri build",
    "build:web": "svelte-kit sync && vite build",
    "build:web:analyze": "svelte-kit sync && cross-env SPIRE_BUNDLE_REPORT=1 vite build",
    "check": "svelte-kit sync && svelte-check --tsconfig ./tsconfig.json",
    "test:unit": "vitest run",
    "test:unit:watch": "vitest",
    "test:e2e": "playwright test",
    "test:e2e:headed": "playwright test --headed"
  },
  "dependencies": {
    "@tauri-apps/api": "^1.5.0",
    "chart.js": "^4.5.1",
    "katex": "^0.16.11",
    "lucide-svelte": "^0.577.0",
    "mermaid": "^11.12.3",
    "svelte": "^5.0.0",
    "three": "^0.183.2",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@playwright/test": "^1.53.2",
    "@sveltejs/adapter-static": "^3.0.0",
    "@sveltejs/kit": "^2.15.0",
    "@sveltejs/vite-plugin-svelte": "^4.0.0",
    "@tauri-apps/cli": "^1.5.0",
    "@types/node": "^25.5.0",
    "@types/three": "^0.183.1",
    "cross-env": "^10.1.0",
    "jsdom": "^26.1.0",
    "rollup-plugin-visualizer": "^7.0.1",
    "svelte-check": "^4.0.0",
    "typescript": "^5.0.0",
    "vite": "^8.0.6",
    "vitest": "^2.1.8"
  }
}
